NODE_ENV=development
PORT=4100
HOST=0.0.0.0
DATABASE_URL=postgresql://chatmod:chatmod@localhost:5432/chatmod
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:4100
JWT_ISSUER=chatmod-mobile-local
JWT_AUDIENCE=chatmod-mobile
JWT_SECRET=replace-with-a-long-random-secret
SECRET_ENCRYPTION_KEYS=primary:replace-with-base64url-32-byte-key
GOOGLE_OAUTH_CLIENT_ID=replace-me
GOOGLE_OAUTH_CLIENT_SECRET=replace-me
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4100/youtube/oauth/callback
GOOGLE_PLAY_PACKAGE_NAME=com.chatmod.mobile
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_BASE64=replace-me
ANDROID_MIN_SUPPORTED_VERSION_CODE=1
ANDROID_MIN_SUPPORTED_VERSION_NAME=0.1.0
ANDROID_LATEST_VERSION_CODE=1
ANDROID_LATEST_VERSION_NAME=0.1.0
ANDROID_UPDATE_URL=https://example.com/chatmod-mobile.apk
SUPPORT_EVENT_RETENTION_DAYS=90
API_ERROR_RETENTION_DAYS=30
STREAM_LOG_RETENTION_DAYS=60
BACKUP_VERSIONS_PER_PROFILE=10
